  102|  13.6M|static inline __m256i _mm256_mulhi_epu32(__m256i a, __m256i b) {
  103|       |    // Multiply bottom 4 items and top 4 items together.
  104|  13.6M|    __m256i ab_hm = _mm256_mul_epu32(_mm256_srli_epi64(a, 32),
  105|  13.6M|                                     _mm256_srli_epi64(b, 32));
  106|  13.6M|    __m256i ab_lm = _mm256_srli_epi64(_mm256_mul_epu32(a, b), 32);

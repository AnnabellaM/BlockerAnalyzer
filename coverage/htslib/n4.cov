  110|       |//    // Shift to get hi 32-bit of each 64-bit product
  111|       |//    ab_hm = _mm256_and_si256(ab_hm,
  112|       |//                       _mm256_set1_epi64x((uint64_t)0xffffffff00000000));
  113|       |//

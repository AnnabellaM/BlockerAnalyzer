  431|       |	} else
  432|       |		snprintf(p, errbuflen_remaining, " (%lu)", errnum);
  433|       |
  434|       |	/*
  435|       |	 * Now, if we're not in UTF-8 mode, convert errbuf to the
  436|       |	 * local code page.
  437|       |	 */
  438|       |	if (!use_utf_8)

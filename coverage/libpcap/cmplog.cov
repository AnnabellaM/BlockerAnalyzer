  802|       | *
  803|       | * See Documentation/networking/can.txt in the Linux source.
  804|       | *
  805|       | * Requested by Felix Obenhuber <felix@obenhuber.de>.
  806|       | */
  807|       |#define LINKTYPE_CAN_SOCKETCAN	227

 4963|       |		/*
 4964|       |		 * OK, it's already a monitor mode device; just use it.
 4965|       |		 * There's no point in creating another monitor device
 4966|       |		 * that will have to be cleaned up.
 4967|       |		 */
 4968|       |		nl80211_cleanup(&nlstate);

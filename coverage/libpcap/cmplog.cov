 1748|       |	/*
 1749|       |	 * RFC 3986 says:
 1750|       |	 *
 1751|       |	 *   URI         = scheme ":" hier-part [ "?" query ] [ "#" fragment ]
 1752|       |	 *
 1753|       |	 *   hier-part   = "//" authority path-abempty
 1754|       |	 *               / path-absolute
 1755|       |	 *               / path-rootless
 1756|       |	 *               / path-empty
 1757|       |	 *
 1758|       |	 *   authority   = [ userinfo "@" ] host [ ":" port ]
 1759|       |	 *
 1760|       |	 *   userinfo    = *( unreserved / pct-encoded / sub-delims / ":" )
 1761|       |         *

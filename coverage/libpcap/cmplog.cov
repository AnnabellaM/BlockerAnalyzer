 1728|       |	if (source == NULL) {
 1729|       |		snprintf(ebuf, PCAP_ERRBUF_SIZE,
 1730|       |		    "The source string must not be NULL.");
 1731|       |		return (-1);
 1732|       |	}
 1733|       |	if (! strcmp(source, "")) {
 1734|       |		snprintf(ebuf, PCAP_ERRBUF_SIZE,
 1735|       |		    "The source string must not be empty.");
 1736|       |		return (-1);
 1737|       |	}
 1738|       |
 1739|       |	/*
 1740|       |	 * Start out returning nothing.
 1741|       |	 */
 1742|       |	*schemep = NULL;
 1743|       |	*userinfop = NULL;
 1744|       |	*hostp = NULL;
 1745|       |	*portp = NULL;
 1746|       |	*pathp = NULL;

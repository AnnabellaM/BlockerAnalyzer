 1795|       |		/*
 1796|       |		 * The source is the device to open.
 1797|       |		 * Return a NULL pointer for the scheme, user information,
 1798|       |		 * host, and port, and return the device as the path.
 1799|       |		 */
 1800|       |		*pathp = strdup(source);
 1801|       |		if (*pathp == NULL) {
 1802|       |			pcapint_fmt_errmsg_for_errno(ebuf, PCAP_ERRBUF_SIZE,
 1803|       |			    errno, "malloc");
 1804|       |			return (-1);
 1805|       |		}
 1806|       |		return (0);
 1807|       |	}
 1808|       |
 1809|       |	/*
 1810|       |	 * XXX - check whether the purported scheme could be a scheme?
 1811|       |	 */
 1812|       |
 1813|       |	/*
 1814|       |	 * OK, this looks like a URL.

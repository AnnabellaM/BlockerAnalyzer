  334|       |/*
  335|       | * A valid jump instruction code is a bitwise OR of three values and one of the
  336|       | * values is BPF_JMP.  To make sure both of the other two values are always
  337|       | * present, define a macro of two arguments and use it instead of ORing the
  338|       | * values in place.
  339|       | *
  340|       | * Note that "ja L" (documented as "jmp L" in the 1993 BPF paper) does not quite
  341|       | * follow the pattern and there is no "ja x", but internally it works very much
  342|       | * like "ja #k", so JMP(BPF_JA, BPF_K) is appropriate enough.
  343|       | */
  344|  56.7k|#define JMP(jtype, src) (BPF_JMP | (jtype) | (src))
  345|       |
  346|       |/*
  347|       | * "Push" the current value of the link-layer header type and link-layer
  348|       | * header offset onto a "stack", and set a new value.  (It's not a
  349|       | * full-blown stack; we keep only the top two items.)
  350|       | */
  351|    211|#define PUSH_LINKHDR(cs, new_linktype, new_is_variable, new_constant_part, new_reg) \
  352|    211|{ \
  353|    211|	(cs)->prevlinktype = (cs)->linktype; \
  354|    211|	(cs)->off_prevlinkhdr = (cs)->off_linkhdr; \
  355|    211|	(cs)->linktype = (new_linktype); \
  356|    211|	(cs)->off_linkhdr.is_variable = (new_is_variable); \
  357|    211|	(cs)->off_linkhdr.constant_part = (new_constant_part); \
  358|    211|	(cs)->off_linkhdr.reg = (new_reg); \
  359|    211|	(cs)->is_encap = 0; \
  360|    211|}
  361|       |
  362|       |/*
  363|       | * Offset "not set" value.
  364|       | */
  365|  31.9k|#define OFFSET_NOT_SET	0xffffffffU
  366|       |
  367|       |/*
  368|       | * Absolute offsets, which are offsets from the beginning of the raw
  369|       | * packet data, are, in the general case, the sum of a variable value
  370|       | * and a constant value; the variable value may be absent, in which
  371|       | * case the offset is only the constant value, and the constant value
  372|       | * may be zero, in which case the offset is only the variable value.
  373|       | *
  374|       | * bpf_abs_offset is a structure containing all that information:
  375|       | *
  376|       | *   is_variable is 1 if there's a variable part.
  377|       | *
  378|       | *   constant_part is the constant part of the value, possibly zero;
  379|       | *
  380|       | *   if is_variable is 1, reg is the register number for a register
  381|       | *   containing the variable value if the register has been assigned,
  382|       | *   and -1 otherwise.
  383|       | */
  384|       |typedef struct {
  385|       |	int	is_variable;
  386|       |	u_int	constant_part;
  387|       |	int	reg;
  388|       |} bpf_abs_offset;
  389|       |
  390|       |/*
  391|       | * Value passed to gen_load_a() to indicate what the offset argument
  392|       | * is relative to the beginning of.
  393|       | */
  394|       |enum e_offrel {
  395|       |	OR_PACKET,		/* full packet data */
  396|       |	OR_LINKHDR,		/* link-layer header */
  397|       |	OR_PREVLINKHDR,		/* previous link-layer header */
  398|       |	OR_LLC,			/* 802.2 LLC header */
  399|       |	OR_PREVMPLSHDR,		/* previous MPLS header */
  400|       |	OR_LINKTYPE,		/* link-layer type */
  401|       |	OR_LINKPL,		/* link-layer payload */
  402|       |	OR_LINKPL_NOSNAP,	/* link-layer payload, with no SNAP header at the link layer */
  403|       |	OR_TRAN_IPV4,		/* transport-layer header, with IPv4 network layer */
  404|       |	OR_TRAN_IPV6		/* transport-layer header, with IPv6 network layer */
  405|       |};
  406|       |
  407|       |/*
  408|       | * We divvy out chunks of memory rather than call malloc each time so
  409|       | * we don't have to worry about leaking memory.  It's probably
  410|       | * not a big deal if all this memory was wasted but if this ever
  411|       | * goes into a library that would probably not be a good idea.
  412|       | *
  413|       | * XXX - this *is* in a library....
  414|       | */
  415|   108k|#define NCHUNKS 16
  416|  6.38k|#define CHUNK0SIZE 1024
  417|       |struct chunk {
  418|       |	size_t n_left;
  419|       |	void *m;
  420|       |};
  421|       |
  422|       |/*
  423|       | * A chunk can store any of:
  424|       | *  - a string (guaranteed alignment 1 but present for completeness)
  425|       | *  - a block
  426|       | *  - an slist
  427|       | *  - an arth
  428|       | * For this simple allocator every allocated chunk gets rounded up to the
  429|       | * alignment needed for any chunk.
  430|       | */
  431|       |struct chunk_align {
  432|       |	char dummy;
  433|       |	union {
  434|       |		char c;
  435|       |		struct block b;
  436|       |		struct slist s;
  437|       |		struct arth a;
  438|       |	} u;
  439|       |};
  440|   474k|#define CHUNK_ALIGN (offsetof(struct chunk_align, u))

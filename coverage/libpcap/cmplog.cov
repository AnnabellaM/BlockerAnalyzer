  146|       |   * HP-UX) declares the function there.  HP-UX declares the function in
  147|       |   * <string.h>, which has already been included.
  148|       |   */
  149|       |  #include <strings.h>
  150|       |  #define lowest_set_bit(mask)	((u_int)(ffs((mask)) - 1))
  151|       |#endif

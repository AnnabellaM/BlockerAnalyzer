 1659|       | *    https://www.elektrobit.com/ebhscr
 1660|       | *
 1661|       | * For DLT_USBPCAP, the maximum is 1MiB, as per
 1662|       | *
 1663|       | *    https://bugs.wireshark.org/bugzilla/show_bug.cgi?id=15985
 1664|       | */
 1665|       |u_int
 1666|       |max_snaplen_for_dlt(int dlt)
 1667|  32.8k|{
 1668|  32.8k|	switch (dlt) {
 1669|       |
 1670|    465|	case DLT_DBUS:
  ------------------
  |  Branch (1670:2): [True: 465, False: 32.3k]
  ------------------
 1671|    465|		return 128*1024*1024;
 1672|       |
 1673|      3|	case DLT_EBHSCR:
  ------------------
  |  Branch (1673:2): [True: 3, False: 32.7k]
  ------------------
 1674|      3|		return 8*1024*1024;
 1675|       |
 1676|  1.86k|	case DLT_USBPCAP:
  ------------------
  |  Branch (1676:2): [True: 1.86k, False: 30.9k]
  ------------------
 1677|  1.86k|		return 1024*1024;
 1678|       |
 1679|  30.4k|	default:
  ------------------
  |  Branch (1679:2): [True: 30.4k, False: 2.33k]
  ------------------
 1680|  30.4k|		return MAXIMUM_SNAPLEN;
 1681|  32.8k|	}
 1682|  32.8k|}


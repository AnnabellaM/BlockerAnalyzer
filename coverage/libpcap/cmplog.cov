 1771|       |		 * The source is the device to open.
 1772|       |		 * Return a NULL pointer for the scheme, user information,
 1773|       |		 * host, and port, and return the device as the path.
 1774|       |		 */
 1775|       |		*pathp = strdup(source);
 1776|       |		if (*pathp == NULL) {
 1777|       |			pcapint_fmt_errmsg_for_errno(ebuf, PCAP_ERRBUF_SIZE,
 1778|       |			    errno, "malloc");
 1779|       |			return (-1);

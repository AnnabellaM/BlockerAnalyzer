 9819|      0|	newoff_sio = cstate->off_sio;
 9820|      0|	newoff_opc = cstate->off_opc;
 9821|      0|	newoff_dpc = cstate->off_dpc;
 9822|      0|	newoff_sls = cstate->off_sls;
 9823|       |
 9824|      0|	assert_ss7(cstate, ss7kw(mtp3field));
 9825|       |
 9826|      0|	switch (mtp3field) {
 9827|       |
 9828|       |	/*
 9829|       |	 * See UTU-T Rec. Q.703, Section 2.2, Figure 3/Q.703.
 9830|       |	 *
 9831|       |	 * SIO is the simplest field: the size is one byte and the offset is a
 9832|       |	 * multiple of bytes, so the only detail to get right is the value of
 9833|       |	 * the [right-to-left] field offset.
 9834|       |	 */
 9835|      0|	case MH_SIO:
  ------------------
  |  Branch (9835:2): [True: 0, False: 0]
  ------------------
 9836|      0|		newoff_sio += 3; /* offset for MTP2_HSL */
 9837|       |		/* FALLTHROUGH */
 9838|       |
 9839|      0|	case M_SIO:
  ------------------
  |  Branch (9839:2): [True: 0, False: 0]
  ------------------
 9840|      0|		assert_maxval(cstate, ss7kw(mtp3field), jvalue, MTP2_SIO_MAXVAL);
 9841|       |		// Here the bitmask means "do not apply a bitmask".
 9842|      0|		return gen_ncmp(cstate, OR_PACKET, newoff_sio, BPF_B, UINT32_MAX,
 9843|      0|		    jtype, reverse, jvalue);
 9844|       |
 9845|       |	/*
 9846|       |	 * See UTU-T Rec. Q.704, Section 2.2, Figure 3/Q.704.
 9847|       |	 *
 9848|       |	 * SLS, OPC and DPC are more complicated: none of these is sized in a
 9849|       |	 * multiple of 8 bits, MTP3 encoding is little-endian and MTP packet
 9850|       |	 * diagrams are meant to be read right-to-left.  This means in the
 9851|       |	 * diagrams within individual fields and concatenations thereof
 9852|       |	 * bitwise shifts and masks can be noted in the common left-to-right
 9853|       |	 * manner until each final value is ready to be byte-swapped and
 9854|       |	 * handed to gen_ncmp().  See also gen_dnhostop(), which solves a
 9855|       |	 * similar problem in a similar way.
 9856|       |	 *
 9857|       |	 * Offsets of fields within the packet header always have the
 9858|       |	 * right-to-left meaning.  Note that in DLT_MTP2 and possibly other
 9859|       |	 * DLTs the offset does not include the F (Flag) field at the
 9860|       |	 * beginning of each message.
 9861|       |	 *
 9862|       |	 * For example, if the 8-bit SIO field has a 3 byte [RTL] offset, the
 9863|       |	 * 32-bit standard routing header has a 4 byte [RTL] offset and could
 9864|       |	 * be tested entirely using a single BPF_W comparison.  In this case
 9865|       |	 * the 14-bit DPC field [LTR] bitmask would be 0x3FFF, the 14-bit OPC
 9866|       |	 * field [LTR] bitmask would be (0x3FFF << 14) and the 4-bit SLS field
 9867|       |	 * [LTR] bitmask would be (0xF << 28), all of which conveniently
 9868|       |	 * correlates with the [RTL] packet diagram until the byte-swapping is
 9869|       |	 * done before use.
 9870|       |	 *
 9871|       |	 * The code below uses this approach for OPC, which spans 3 bytes.
 9872|       |	 * DPC and SLS use shorter loads, SLS also uses a different offset.
 9873|       |	 */

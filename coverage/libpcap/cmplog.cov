  512|       |	 *
  513|       |	 * For Ethernet, it's the offset of the Ethernet type field; this
  514|       |	 * means that it must have a value that skips VLAN tags.
  515|       |	 *
  516|       |	 * For link-layer types that always use 802.2 headers, it's the
  517|       |	 * offset of the LLC header; this means that it must have a value
  518|       |	 * that skips VLAN tags.
  519|       |	 *
  520|       |	 * For PPP, it's the offset of the PPP type field.
  521|       |	 *
  522|       |	 * For Cisco HDLC, it's the offset of the CHDLC type field.
  523|       |	 *
  524|       |	 * For BSD loopback, it's the offset of the AF_ value.
  525|       |	 *
  526|       |	 * For Linux cooked sockets, it's the offset of the type field.
  527|       |	 *
  528|       |	 * off_linktype.constant_part is set to OFFSET_NOT_SET for no
  529|       |	 * encapsulation, in which case, IP is assumed.
  530|       |	 */
  531|       |	bpf_abs_offset off_linktype;

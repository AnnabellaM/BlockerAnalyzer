 5218|      0|	}
 5219|       |	/*
 5220|       |	 * In a DECnet message inside an Ethernet frame the first two bytes
 5221|       |	 * immediately after EtherType are the [little-endian] DECnet message
 5222|       |	 * length, which is irrelevant in this context.
 5223|       |	 *
 5224|       |	 * "pad = 1" means the third byte equals 0x81, thus it is the PLENGTH
 5225|       |	 * 8-bit bitmap of the optional padding before the packet route header.
 5226|       |	 * The bitmap always has bit 7 set to 1 and in this case has bits 0-6
 5227|       |	 * (TOTAL-PAD-SEQUENCE-LENGTH) set to integer value 1.  The latter
 5228|       |	 * means there aren't any PAD bytes after the bitmap, so the header
 5229|       |	 * begins at the fourth byte.  "pad = 0" means bit 7 of the third byte
 5230|       |	 * is set to 0, thus the header begins at the third byte.
 5231|       |	 *
 5232|       |	 * The header can be in several (as mentioned above) formats, all of
 5233|       |	 * which begin with the FLAGS 8-bit bitmap, which always has bit 7
 5234|       |	 * (PF, "pad field") set to 0 regardless of any padding present before
 5235|       |	 * the header.  "Short header" means bits 0-2 of the bitmap encode the
 5236|       |	 * integer value 2 (SFDP), and "long header" means value 6 (LFDP).
 5237|       |	 *

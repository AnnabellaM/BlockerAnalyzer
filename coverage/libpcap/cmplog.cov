 9947|      0|	assert_atm(cstate, atmkw(type));
 9948|       |
 9949|      0|	switch (type) {
 9950|       |
 9951|      0|	case A_OAM:
  ------------------
  |  Branch (9951:2): [True: 0, False: 0]
  ------------------
 9952|       |		/* OAM F4 type */

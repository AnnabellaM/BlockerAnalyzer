 1844|       |		*pathp = strdup(colonp + 3);
 1845|       |		if (*pathp == NULL) {
 1846|       |			pcapint_fmt_errmsg_for_errno(ebuf, PCAP_ERRBUF_SIZE,
 1847|       |			    errno, "malloc");
 1848|       |			free(scheme);
 1849|       |			return (-1);
 1850|       |		}

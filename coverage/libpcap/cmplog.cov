 5164|       |/*
 5165|       | * This is quite tricky because there may be pad bytes in front of the
 5166|       | * DECNET header, and then there are two possible data packet formats that
 5167|       | * carry both src and dst addresses, plus 5 packet types in a format that
 5168|       | * carries only the src node, plus 2 types that use a different format and
 5169|       | * also carry just the src node.
 5170|       | *
 5171|       | * Yuck.
 5172|       | *
 5173|       | * Instead of doing those all right, we just look for data packets with
 5174|       | * 0 or 1 bytes of padding.  If you want to look at other packets, that
 5175|       | * will require a lot more hacking.
 5176|       | *
 5177|       | * To add support for filtering on DECNET "areas" (network numbers)
 5178|       | * one would want to add a "mask" argument to this routine.  That would
 5179|       | * make the filter even more inefficient, although one could be clever
 5180|       | * and not generate masking instructions if the mask is 0xFFFF.
 5181|       | */
 5182|       |static struct block *
 5183|       |gen_dnhostop(compiler_state_t *cstate, bpf_u_int32 addr, int dir)
 5184|      0|{
 5185|      0|	struct block *b0, *b1, *b2, *tmp;
 5186|      0|	u_int offset_lh;	/* offset if long header is received */
 5187|      0|	u_int offset_sh;	/* offset if short header is received */
 5188|       |
 5189|      0|	switch (dir) {
 5190|       |
 5191|      0|	case Q_DST:
  ------------------
  |  Branch (5191:2): [True: 0, False: 0]
  ------------------
 5192|      0|		offset_sh = 1;	/* follows flags */
 5193|      0|		offset_lh = 7;	/* flgs,darea,dsubarea,HIORD */
 5194|      0|		break;
 5195|       |
 5196|      0|	case Q_SRC:
  ------------------
  |  Branch (5196:2): [True: 0, False: 0]
  ------------------
 5197|      0|		offset_sh = 3;	/* follows flags, dstnode */
 5198|      0|		offset_lh = 15;	/* flgs,darea,dsubarea,did,sarea,ssub,HIORD */
 5199|      0|		break;
 5200|       |
 5201|      0|	case Q_AND:
  ------------------
  |  Branch (5201:2): [True: 0, False: 0]
  ------------------
 5202|       |		/* Inefficient because we do our Calvinball dance twice */
